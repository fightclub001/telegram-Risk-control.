BOT_TOKEN=your_bot_token_here
ADMIN_IDS=123456789 987654321
GROUP_IDS=-1001111111111 -1002222222222
LOG_LEVEL=INFO
DATA_DIR=/app/data

# Local Ubuntu primary node identity
PRIMARY_NODE_ID=ubuntu-main

# Cloudflare Worker heartbeat endpoints
HEARTBEAT_WRITE_URL=https://your-worker.example.workers.dev/heartbeat
HEARTBEAT_WRITE_TOKEN=replace-with-write-token
HEARTBEAT_STATUS_URL=https://your-worker.example.workers.dev/status
HEARTBEAT_STATUS_TOKEN=replace-with-read-token

# Tune if needed
HEARTBEAT_INTERVAL_SEC=15
HEARTBEAT_MAX_AGE_SEC=90
HEARTBEAT_POLL_SEC=15
HEARTBEAT_TIMEOUT_SEC=5
# Failover hysteresis:
# - Fail side: require N consecutive unhealthy probes before Railway starts standby
# - Recover side: stop Railway standby immediately after first healthy probe from Ubuntu
HEARTBEAT_FAIL_CONFIRM_LOOPS=3
HEARTBEAT_RECOVER_CONFIRM_LOOPS=1

# Optional: keep Ubuntu + Railway admin-editable state in sync through Railway volume
# Set Railway service URL for config sync endpoint, e.g. https://<service>.up.railway.app/config
CONFIG_SYNC_URL=
CONFIG_SYNC_TOKEN=replace-with-strong-shared-token
CONFIG_SYNC_TIMEOUT_SEC=5
CONFIG_SYNC_PULL_ON_START=true
CONFIG_SYNC_PUSH_ON_SAVE=true
# Optional legacy endpoint for image_fuzzy_blocks.json sync.
# If empty, main.py auto-derives it from CONFIG_SYNC_URL by replacing /config -> /image-fuzzy-blocks
IMAGE_FUZZY_SYNC_URL=
# Optional explicit admin-state endpoints; if empty, main.py auto-derives:
#   /state-manifest and /state-bundle from CONFIG_SYNC_URL
STATE_SYNC_MANIFEST_URL=
STATE_SYNC_BUNDLE_URL=
# Railway side endpoint settings (usually defaults are fine)
CONFIG_SYNC_PORT=8080
CONFIG_SYNC_PATH=/config
IMAGE_FUZZY_SYNC_PATH=/image-fuzzy-blocks
STATE_SYNC_MANIFEST_PATH=/state-manifest
STATE_SYNC_BUNDLE_PATH=/state-bundle
