<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>ai.telegram-risk-control</string>

    <key>ProgramArguments</key>
    <array>
        <string>/bin/sh</string>
        <string>-c</string>
        <string>set -a; . /Users/cyber/workshop/telegram-Risk-control/.env; set +a; exec /Users/cyber/workshop/telegram-Risk-control/venv/bin/python /Users/cyber/workshop/telegram-Risk-control/main.py</string>
    </array>

    <key>WorkingDirectory</key>
    <string>/Users/cyber/workshop/telegram-Risk-control</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>DATA_DIR</key>
        <string>/Users/cyber/workshop/telegram-Risk-control/data</string>
        <key>PATH</key>
        <string>/Users/cyber/workshop/telegram-Risk-control/venv/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>

    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>

    <key>ThrottleInterval</key>
    <integer>10</integer>

    <key>StandardOutPath</key>
    <string>/Users/cyber/Library/Logs/telegram-risk-control.log</string>

    <key>StandardErrorPath</key>
    <string>/Users/cyber/Library/Logs/telegram-risk-control.log</string>
</dict>
</plist>
